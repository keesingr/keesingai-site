    referenceTitle: "A.I., Captain: The Robotic Navy Ship of the Future",
    referenceSource: "Fortune",
    referenceUrl:
      "https://fortune.com/longform/leidos-sea-hunter-ai-navy-ship/",
    referenceType: "Feature",
  },
  {
    capability: "Collaborative Autonomy",
    examples: "DARPA Gremlins",
    referenceTitle: "Gremlins Airborne Recovery Demonstration",
    referenceSource: "DARPA",
    referenceUrl: "https://www.youtube.com/watch?v=H4T6Vr4a1hY",
    referenceType: "Video",
  },
