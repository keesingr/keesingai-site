    referenceTitle: "Mezzo™",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/markets/homeland/ports-borders/mezzo",
    referenceType: "Portfolio",
  },
];

const transportationExamples = [
  {
    capability: "Mission-Critical Software",
    examples:
      "AI-assisted software engineering for complex operational and mission systems",
    referenceTitle:
      "Leveraging AI to Tackle Big Challenges in Intelligence, Software Development, and Fraud Protection",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/insights/leveraging-ai-tackle-big-challenges-intelligence-software-development-and-fraud-protection",
    referenceType: "Article",
  },
  {
    capability: "Aviation Operations",
    examples:
      "Air traffic management, arrival sequencing, and operational decision support",
    referenceTitle: "Intelligent Approach",
    referenceSource: "NATS",
    referenceUrl:
      "https://www.nats.aero/our-solutions/intelligent-approach/",
    referenceType: "Solution",
  },
  {
    capability: "Logistics & Supply Chains",
    examples:
      "Supply chain optimization, planning, and operational decision support",
    referenceTitle: "Digital Supply Chain",
    referenceSource: "YouTube",
    referenceUrl:
      "https://www.youtube.com/watch?v=bmeB21luc_c&t=1s",
    referenceType: "Video",
  },
];
const infrastructureExamples = [
  {
    capability: "Energy Systems",
    examples:
      "Grid optimization, resilience, forecasting, and operational decision support",
    referenceTitle:
      "How AI Is Transforming the Electric Grid",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/insights/how-ai-transforming-electric-grid",
    referenceType: "Article",
  },
  {
    capability: "Industrial Operations",
    examples:
      "AI-enabled inspection, monitoring, and operational automation",
    referenceTitle:
      "Innovation Technology",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/markets/aviation/security-detection/innovation-technology",
    referenceType: "Technology",
  },
  {
    capability: "Disaster Response",
    examples:
      "Agentic AI supporting emergency management, situational awareness, and coordinated response",
    referenceTitle:
      "Leidos Uses AI Agents to Improve Disaster Response",
    referenceSource: "NVIDIA",
    referenceUrl:
      "https://www.nvidia.com/en-us/case-studies/leidos-uses-ai-agents-to-improve-disaster-response/",
    referenceType: "Case Study",
