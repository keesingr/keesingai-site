---
import Header from "../components/Header.astro";
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";

const autonomyExamples = [
  {
    capability: "Space Autonomy",
    examples: "NASA Deep Space 1 — Remote Agent",
    referenceTitle: "Remote Agent Experiment Meets All Objectives",
    referenceSource: "NASA Jet Propulsion Laboratory",
