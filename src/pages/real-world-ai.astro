    examples:
      "Clinical workflow optimization, document intelligence, and improved access to care",
    referenceTitle:
      "How Emerging Tech is Improving Veteran Health Care, Access",
    referenceSource: "GovCIO Media",
    referenceUrl:
      "https://govciomedia.com/how-emerging-tech-is-improving-veteran-health-care-access/",
    referenceType: "Article",
  },
];
const decisionExamples = [
  {
    capability: "Command & Control",
    examples:
      "AI-assisted battle management, mission planning, and human-machine teaming",
    referenceTitle:
      "AlphaMosaic: AI-Powered Battle Management Takes Flight",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/insights/alphamosaic-ai-powered-battle-management-takes-flight",
    referenceType: "Article",
  },
  {
    capability: "Predictive Analytics",
    examples:
      "Forecasting, talent analytics, and operational decision support",
    referenceTitle:
      "Leidos R2View: Revolutionizing Cleared Recruitment with Proven AI",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/insights/leidos-r2view-revolutionizing-cleared-recruitment-proven-ai",
    referenceType: "Article",
  },
  {
    capability: "Intelligence Analysis",
    examples:
      "AI-enabled intelligence fusion, analytic tradecraft, and mission support",
    referenceTitle:
      "Leidos Awarded $143M DIA Technology Platform Contract",
    referenceSource: "Leidos",
    referenceUrl:
      "https://www.leidos.com/insights/leidos-awarded-143m-dia-technology-platform-contract",
    referenceType: "Article",
  },
