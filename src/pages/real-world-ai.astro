const healthcareExamples = [
  {
    capability: "Biomedical Research",
    examples:
      "Knowledge extraction, scientific discovery, and biomedical reasoning",
    referenceTitle: "DARPA's Big Mechanism Program",
    referenceSource: "ResearchGate",
