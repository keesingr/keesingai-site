---
import { getCollection } from "astro:content";

import Header from "../components/Header.astro";
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";

const entries = (
  await getCollection("perspectives", ({ data }) => data.draft !== true)
).sort((a, b) => a.data.order - b.data.order);

const executiveBriefs = entries.filter(
  (entry) => entry.data.type === "Executive Brief",
);

const essaysAndPosts = entries.filter(
  (entry) => entry.data.type === "Essay" || entry.data.type === "Post",
);
---

<MainLayout
  title="Perspectives | Ron Keesing"
  description="Ideas, conversations, executive briefs, essays, posts, and presentations on enterprise AI."
>
  <Header activePage="perspectives" />

  <main>
    <section class="page-introduction">
      <div class="site-container">
        <h1>Perspectives</h1>

        <p>
          Ideas, conversations, and presentations on enterprise AI strategy,
          governance, human-centered transformation, and the practical
          realities of deploying AI at scale.
        </p>
      </div>
    </section>

    <section class="content-section">
      <div class="site-container">
        <SectionHeader title="Featured Conversation" />
<article class="featured-item">
  <div class="featured-image">
    <img
      src="/images/aws-chat.png"
      alt="Ron Keesing in conversation with AWS Executive Strategist Tom Soderstrom"
      loading="lazy"
    />
  </div>

  <div class="featured-content">
    <p class="content-type">AWS Executive Insights</p>

    <h3>
      Leading AI Transformation: A Chief AI Officer’s Perspective
    </h3>

    <p>
      A conversation with AWS Executive Strategist Tom Soderstrom about
      enterprise AI strategy, governance, organizational transformation,
      and lessons learned while building and leading AI capabilities at
      scale.
    </p>

    <a
      href="https://aws.amazon.com/executive-insights/podcast/leading-enterprise-ai-governance-and-transformation-with-ron-keesing/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Watch Leading AI Transformation: A Chief AI Officer’s Perspective, opens in a new tab"
    >
      Watch the conversation <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
      </div>
    </section>

    {
      executiveBriefs.length > 0 && (
        <section class="content-section">
          <div class="site-container">
            <SectionHeader
              title={
                executiveBriefs.length === 1
                  ? "Executive Brief"
                  : "Executive Briefs"
              }
            />

            <div class="item-list">
              {executiveBriefs.map((entry) => (
                <article class="list-item">
                  <p class="content-type">{entry.data.type}</p>

                  <h3>{entry.data.title}</h3>

                  <p>{entry.data.description}</p>

                  <a href={`/perspectives/${entry.id}/`}>
                    Read the executive brief{" "}
                    <span aria-hidden="true">→</span>
                  </a>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      essaysAndPosts.length > 0 && (
        <section class="content-section">
          <div class="site-container">
            <SectionHeader title="Essays & Posts" />

            <div class="item-list">
              {essaysAndPosts.map((entry) => (
                <article class="list-item">
                  <p class="content-type">{entry.data.type}</p>

                  <h3>{entry.data.title}</h3>

                  <p>{entry.data.description}</p>

                  <a href={`/perspectives/${entry.id}/`}>
                    Read <span aria-hidden="true">→</span>
                  </a>
                </article>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="content-section">
      <div class="site-container">
        <SectionHeader title="Presentations" />

        <div class="item-list">
          <article class="list-item">
            <p class="content-type">Presentation</p>

            <h3>Mission AI vs. Sandbox AI</h3>

            <p>
              Why organizations need to move beyond isolated AI tools and
              integrate AI into operational workflows, enterprise data, and
              governance systems.
            </p>

            <span class="coming-soon">Presentation link to be added</span>
          </article>

          <article class="list-item">
            <p class="content-type">Presentation</p>

            <h3>AI Governance 2.0</h3>

            <p>
              How autonomous agents and increasingly capable foundation models
              change the requirements for enterprise AI governance, assurance,
              and accountability.
            </p>

            <span class="coming-soon">Presentation link to be added</span>
          </article>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .page-introduction {
    padding: clamp(3.5rem, 6vw, 5.5rem) 0;
  }

  .page-introduction h1 {
    margin: 0 0 1.25rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(2.7rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .page-introduction p {
    max-width: 820px;
    margin: 0;
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.7;
  }

  .content-section {
    padding: clamp(3rem, 5vw, 4.5rem) 0;
    border-top: 1px solid var(--line);
  }

 .featured-item {
  display: grid;
  grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1.4fr);
  gap: clamp(2rem, 6vw, 5rem);
  align-items: start;
}

.featured-image {
  overflow: hidden;
  aspect-ratio: 16 / 9;
  background: var(--white);
}

.featured-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.featured-content {
  max-width: 760px;
  min-width: 0;
}

.list-item {
  max-width: 860px;
}

  .content-type {
    margin: 0 0 0.65rem;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  article h3 {
    margin: 0 0 0.85rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.4vw, 2rem);
    font-weight: 600;
    line-height: 1.2;
  }

  article p {
    margin: 0 0 1rem;
    font-size: clamp(0.98rem, 1.3vw, 1.08rem);
    line-height: 1.7;
  }

  article a {
    color: var(--accent);
    font-weight: 500;
  }

  article a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .item-list {
    border-bottom: 1px solid var(--line);
  }

  .list-item {
    padding: 1.8rem 0;
    border-top: 1px solid var(--line);
  }

  .coming-soon {
    color: var(--muted);
    font-size: 0.92rem;
    font-style: italic;
  }
  @media (max-width: 700px) {
  .featured-item {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .featured-image {
    max-width: 620px;
  }
}
</style>

