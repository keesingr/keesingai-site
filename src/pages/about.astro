---
import Header from "../components/Header.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="About | Ron Keesing"
  description="Leadership, teaching, public service, recognition, publications, patents, and education."
>
  <Header activePage="about" />

  <main>
    <section class="page-introduction">
      <div class="site-container introduction-layout">
        <div class="portrait">
          <img
            src="/images/headshot.jpg"
            alt="Portrait of Ron Keesing"
          />
        </div>

        <div class="introduction-content">
          <h1>About</h1>

          <p>
            Artificial intelligence has shaped my career for more than two
            decades, but my enduring interest has been less about the technology
            itself than about how people and organizations adapt to
            technological change. From AI research, to teaching computer
            science, to enterprise technology leadership and serving as Chief
            AI Officer, I've focused on helping organizations develop and apply emerging
            technologies thoughtfully, responsibly, and at scale.
          </p>

          <p>
            Throughout that journey, one lesson has remained remarkably
            consistent: successful AI transformation depends as much on
            people as it does on algorithms and software. That thinking is reflected throughout this website
            and continues to shape my work with executives, technologists, and
            public leaders.
          </p>
        </div>
      </div>
    </section>

    <div class="about-sections site-container">
      <section
        class="about-section"
        aria-labelledby="leadership-heading"
      >
        <div class="section-copy">
          <h2 id="leadership-heading">Leadership</h2>

          <p>
            I believe that technology leaders have a responsibility to
            contribute their expertise broadly. Throughout my career, I've
            been fortunate to serve in leadership roles spanning community
            organizations, public service, and technology policy.
          </p>
        </div>

        <div class="editorial-list leadership-list">
          <div class="editorial-item">
            <p class="item-role">Chair</p>
            <p class="item-name">
              McLean Community Center Governing Board
            </p>
          </div>

          <div class="editorial-item">
            <p class="item-role">Founding Member</p>
            <p class="item-name">
              Northern Virginia AI Initiative
            </p>
          </div>

          <div class="editorial-item">
            <p class="item-role">Member</p>
            <p class="item-name">
              Fairfax County Council on Economic Opportunity
            </p>
          </div>

          <div class="editorial-item">
            <p class="item-role">Member</p>
            <p class="item-name">
              CNAS Task Force on AI and National Security
            </p>
          </div>

          <div class="editorial-item">
            <p class="item-role">Additional Service</p>
            <p class="item-name">
              Advisory, governance, and nonprofit leadership roles
            </p>
          </div>
        </div>
      </section>

      <section
        class="about-section teaching-section"
        aria-labelledby="teaching-heading"
      >
        <div class="section-copy">
          <h2 id="teaching-heading">Teaching</h2>

          <p>
            Teaching has been a recurring thread throughout my career, whether
            in the classroom, developing educational programs, or helping
            organizations increase AI capabilities within their workforce.
          </p>
        </div>

        <div class="teaching-topics">
          <article class="teaching-topic">
            <h3>University Teaching</h3>

            <p>
              As a Lecturer in Computer Science at the University of the South
              Pacific, I taught students from twelve Pacific Island nations
              while designing the university's first
              distance-learning computer science curriculum. The program
              expanded access to computer science education across a
              geographically dispersed region to students unable to access 
              the main campus.
            </p>
          </article>

          <article class="teaching-topic">
            <h3>Enterprise AI Education</h3>

            <p>
              More recently, I created <em>AI for Everyone</em> and
              <em>Generative AI for Everyone</em>, enterprise education
              programs designed to help employees understand artificial
              intelligence, its practical applications, and the principles of
              responsible adoption.
            </p>
          </article>
        </div>
      </section>

      <section
        class="about-section recognition-section"
        aria-labelledby="recognition-heading"
      >
        <div class="section-copy">
          <h2 id="recognition-heading">Recognition</h2>
        </div>

        <div class="recognition-grid">
          <section aria-labelledby="professional-recognition-heading">
            <h3 id="professional-recognition-heading">
              Professional Recognition
            </h3>

            <ul class="simple-list">
              <li>Leidos Technical Fellow</li>
              <li>Leidos Annual Achievement Award, two-time recipient</li>
              <li>NASA Software of the Year Award</li>
              <li>MachineCon AI150</li>
              <li>WashingtonExec "Top Exec to Watch"</li>
              <li>Additional industry and organizational recognition</li>
            </ul>
          </section>

          <section aria-labelledby="patents-publications-heading">
            <h3 id="patents-publications-heading">
              Patents &amp; Publications
            </h3>

            <div class="subsection">
              <h4>Selected U.S. Patents</h4>

              <ul class="simple-list">
                <li>
                  Gradient-descent optimization for genetic algorithms
                </li>
                <li>
                  Neural-network activation functions using
                  stochastically encoded signals
                </li>
                <li>
                  Pulse-frequency encoded neural-network architectures
                </li>
              </ul>
            </div>

            <div class="subsection">
              <h4>Selected Publications</h4>

              <ul class="publication-list">
                <li>
                  <a
                    href="https://www.nextgov.com/artificial-intelligence/2023/08/its-time-talk-about-user-responsibility-and-generate-ai/389531/"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="publication-title">
                      It’s Time to Talk About User Responsibility and
                      Generative AI
                    </span>

                    <span class="publication-details">
                      NextGov/FCW, 2023
                    </span>
                  </a>
                </li>

                <li>
                  <a
                    href="http://www.lrec-conf.org/proceedings/lrec2010/pdf/862_Paper.pdf"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="publication-title">
                      The DARPA Machine Reading Program
                    </span>

                    <span class="publication-details">
                      LREC, 2010
                    </span>
                  </a>
                </li>

                <li>
                  <a
                    href="http://ic-www.arc.nasa.gov/ic/projects/Executive/papers/agents98-hybrid.ps"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="publication-title">
                      A Hybrid Procedural/Deductive Executive for Autonomous
                      Spacecraft
                    </span>

                    <span class="publication-details">
                      Autonomous Agents and Multi-Agent Systems, 1999
                    </span>
                  </a>
                </li>

                <li>
                  <span class="publication-title">
                    Evolution and Learning in Neural Networks
                  </span>

                  <span class="publication-details">
                    Advances in Neural Information Processing Systems, 1991
                  </span>
                </li>
              </ul>
            </div>
          </section>
        </div>
      </section>

      <section
        class="about-section education-section"
        aria-labelledby="education-heading"
      >
        <div class="section-copy">
          <h2 id="education-heading">Education</h2>
        </div>

        <div class="education-list">
          <div class="education-item">
            <p class="degree">Master of Business Administration</p>
            <p class="institution">University of Maryland</p>
          </div>

          <div class="education-item">
            <p class="degree">Master of Science</p>
            <p class="institution">Stanford University</p>
          </div>

          <div class="education-item">
            <p class="degree">Bachelor of Science</p>
            <p class="institution">Stanford University</p>
          </div>
        </div>
      </section>
    </div>
  </main>
</MainLayout>

<style>
  .page-introduction {
    padding:
      clamp(3.5rem, 6vw, 5.5rem) 0
      clamp(4rem, 7vw, 6rem);
  }

  .introduction-layout {
    display: grid;
    grid-template-columns:
      minmax(260px, 350px)
      minmax(0, 1fr);
    gap: clamp(3rem, 7vw, 6.5rem);
    align-items: start;
  }

  .portrait {
    overflow: hidden;
  }

  .portrait img {
    width: 100%;
    height: auto;
  }

  .introduction-content {
    min-width: 0;
    padding-top: 0.15rem;
  }

  .introduction-content h1 {
    margin: 0 0 1.5rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(2.7rem, 5vw, 4.5rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .introduction-content p {
    max-width: 850px;
    margin: 0;
    color: var(--text);
    font-size: clamp(1.05rem, 1.55vw, 1.2rem);
    line-height: 1.75;
  }

  .introduction-content p + p {
    margin-top: 1.4rem;
  }

  .about-sections {
    padding-bottom: clamp(5rem, 9vw, 8rem);
  }

  .about-section {
    display: grid;
    grid-template-columns:
      minmax(260px, 0.72fr)
      minmax(0, 1.48fr);
    gap: clamp(3rem, 8vw, 7rem);
    align-items: start;
    padding:
      clamp(4rem, 7vw, 6rem) 0
      clamp(4.5rem, 8vw, 7rem);
    border-top: 1px solid var(--line);
  }

  .section-copy {
    min-width: 0;
  }

  .section-copy h2 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.7vw, 3.3rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .section-copy p {
    max-width: 520px;
    margin: 1.2rem 0 0;
    color: var(--text);
    font-size: clamp(0.98rem, 1.25vw, 1.06rem);
    line-height: 1.72;
  }

  .editorial-list {
    border-bottom: 1px solid var(--line);
  }

  .editorial-item {
    display: grid;
    grid-template-columns: minmax(130px, 0.45fr) minmax(0, 1.55fr);
    gap: 2rem;
    padding: 1.35rem 0;
    border-top: 1px solid var(--line);
  }

  .item-role,
  .item-name {
    margin: 0;
  }

  .item-role {
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .item-name {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.18rem, 1.8vw, 1.5rem);
    font-weight: 500;
    line-height: 1.35;
  }

  .teaching-topics {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .teaching-topic + .teaching-topic {
    padding-top: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--line);
  }

  .teaching-topic h3 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.3vw, 1.9rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .teaching-topic p {
    max-width: 820px;
    margin: 1rem 0 0;
    color: var(--text);
    font-size: clamp(0.98rem, 1.25vw, 1.07rem);
    line-height: 1.75;
  }

  .recognition-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(3rem, 7vw, 6rem);
  }

  .recognition-grid h3 {
    margin: 0 0 1.5rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.3vw, 1.9rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .subsection + .subsection {
    margin-top: 2.75rem;
  }

  .subsection h4 {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .simple-list,
  .publication-list {
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--line);
    list-style: none;
  }

  .simple-list li,
  .publication-list li {
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .publication-list a,
  .publication-list li {
    display: block;
  }

  .publication-title,
  .publication-details {
    display: block;
  }

  .publication-title {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.04rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .publication-details {
    margin-top: 0.25rem;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .publication-list a:hover .publication-title,
  .publication-list a:focus-visible .publication-title {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .education-list {
    border-bottom: 1px solid var(--line);
  }

  .education-item {
    display: grid;
    grid-template-columns: minmax(250px, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    padding: 1.35rem 0;
    border-top: 1px solid var(--line);
  }

  .degree,
  .institution {
    margin: 0;
  }

  .degree {
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.75vw, 1.45rem);
    font-weight: 500;
    line-height: 1.35;
  }

  .institution {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .introduction-layout {
      grid-template-columns: minmax(220px, 300px) minmax(0, 1fr);
      gap: 3rem;
    }

    .about-section {
      grid-template-columns: 1fr;
      gap: 2.75rem;
    }

    .section-copy p {
      max-width: 760px;
    }
  }

  @media (max-width: 720px) {
    .introduction-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .portrait {
      max-width: 420px;
    }

    .recognition-grid {
      grid-template-columns: 1fr;
    }

    .recognition-grid > section + section {
      padding-top: 3rem;
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 560px) {
    .page-introduction {
      padding:
        3rem 0
        4rem;
    }

    .about-section {
      gap: 2.25rem;
      padding:
        3.5rem 0
        4.5rem;
    }

    .editorial-item,
    .education-item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
  }
</style>