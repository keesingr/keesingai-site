---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ron Keesing | Enterprise AI",
  description = "Enterprise AI Strategy, Trusted AI Governance, and Human-Centered AI Transformation.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />

    <footer class="site-footer">
      <div class="site-container footer-inner">
        <span>© {new Date().getFullYear()} Ron Keesing</span>

        <a href="/contact/">Contact</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.88rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 78px;
  }

  .site-footer a:hover {
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 0.25rem;
      padding: 1rem 0;
    }
  }
</style>