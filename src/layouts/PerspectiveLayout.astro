---
import Header from "../components/Header.astro";
import MainLayout from "./MainLayout.astro";

interface Props {
  title: string;
  description: string;
  type: string;
  publishedDate?: Date;
  originalSource?: string;
  originalUrl?: string;
}

const {
  title,
  description,
  type,
  publishedDate,
  originalSource,
  originalUrl,
} = Astro.props;

const formattedDate = publishedDate
  ? publishedDate.toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    })
  : undefined;
---

<MainLayout
  title={`${title} | Ron Keesing`}
  description={description}
>
  <Header activePage="perspectives" />

  <main>
    <article class="perspective">
      <header class="article-header site-container">
        <a class="back-link" href="/perspectives/">
          <span aria-hidden="true">←</span> Perspectives
        </a>

        <p class="content-type">{type}</p>

        <h1>{title}</h1>

        <p class="description">{description}</p>

        {
          (formattedDate || originalSource) && (
            <p class="publication-details">
              {formattedDate && <span>{formattedDate}</span>}

              {formattedDate && originalSource && (
                <span aria-hidden="true"> · </span>
              )}

              {originalSource && originalUrl ? (
                <a href={originalUrl} target="_blank" rel="noreferrer">
                  Originally published on {originalSource}
                </a>
              ) : (
                originalSource && (
                  <span>Originally published on {originalSource}</span>
                )
              )}
            </p>
          )
        }
      </header>

      <div class="article-rule site-container" aria-hidden="true"></div>

      <div class="article-body site-container">
        <slot />
      </div>
    </article>
  </main>
</MainLayout>

<style>
  .article-header {
    max-width: 960px;
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: 2.5rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2.75rem;
    color: var(--accent);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .content-type {
    margin: 0 0 0.75rem;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .description {
    max-width: 790px;
    margin: 1.5rem 0 0;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.65;
  }

  .publication-details {
    margin: 1.35rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .publication-details a {
    color: var(--accent);
  }

  .article-rule {
    max-width: 960px;
    height: 1px;
    background: var(--line);
  }

  .article-body {
    max-width: 790px;
    padding-top: 3rem;
    padding-bottom: clamp(5rem, 9vw, 8rem);
    font-size: clamp(1.02rem, 1.3vw, 1.12rem);
    line-height: 1.8;
  }

  .article-body :global(p) {
    margin: 0 0 1.45rem;
  }

  .article-body :global(h2) {
    margin: 3.25rem 0 1.1rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 500;
    line-height: 1.15;
  }

  .article-body :global(h3) {
    margin: 2.5rem 0 0.8rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .article-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.18rem;
  }

  .article-body :global(blockquote) {
    margin: 2.5rem 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--accent);
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.2em;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.4rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.55rem;
  }

  .article-body :global(strong) {
    font-weight: 600;
  }
</style>